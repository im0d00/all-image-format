<Application
    x:Class="HeicAvifViewer.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:HeicAvifViewer">

    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <XamlControlsResources xmlns="using:Microsoft.UI.Xaml.Controls"/>
            </ResourceDictionary.MergedDictionaries>

            <!-- Converter used by ThumbnailItem data templates -->
            <local:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>

            <!-- Compact button style for the title-bar toolbar -->
            <Style x:Key="SmallButtonStyle" TargetType="Button"
                   BasedOn="{StaticResource DefaultButtonStyle}">
                <Setter Property="Padding" Value="8,5"/>
                <Setter Property="MinWidth" Value="32"/>
                <Setter Property="MinHeight" Value="32"/>
                <Setter Property="FontSize" Value="12"/>
            </Style>

            <!-- Compact toggle button style for the title-bar toolbar -->
            <Style x:Key="SmallToggleButtonStyle" TargetType="ToggleButton"
                   BasedOn="{StaticResource DefaultToggleButtonStyle}">
                <Setter Property="Padding" Value="8,5"/>
                <Setter Property="MinWidth" Value="32"/>
                <Setter Property="MinHeight" Value="32"/>
                <Setter Property="FontSize" Value="12"/>
            </Style>
        </ResourceDictionary>
    </Application.Resources>
</Application>
