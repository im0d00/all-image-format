<UserControl
    x:Class="HeicAvifViewer.ExifMetadataPanel"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:HeicAvifViewer"
    MinWidth="280"
    MaxWidth="340">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0" Padding="16,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="Image Info &amp; EXIF"
                       Style="{StaticResource SubtitleTextBlockStyle}"
                       VerticalAlignment="Center"/>
            <Button Grid.Column="1"
                    x:Name="CloseButton"
                    Click="CloseButton_Click"
                    Style="{StaticResource SmallButtonStyle}"
                    ToolTipService.ToolTip="Close panel"
                    Content="&#xE8BB;"
                    FontFamily="{StaticResource SymbolThemeFontFamily}"
                    FontSize="14"/>
        </Grid>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Padding="16,0,16,16" Spacing="2">

                <!-- Loading indicator -->
                <ProgressRing x:Name="LoadingRing"
                              IsActive="False"
                              Width="28" Height="28"
                              HorizontalAlignment="Center"
                              Margin="0,12"/>

                <!-- No metadata placeholder -->
                <TextBlock x:Name="NoDataText"
                           Text="Open an image to see its metadata."
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                           TextWrapping="Wrap"
                           HorizontalAlignment="Center"
                           Margin="0,24,0,0"/>

                <!-- Dynamic metadata rows are inserted here by code-behind -->
                <ItemsControl x:Name="MetadataItems">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="local:MetadataEntry">
                            <Grid Padding="0,5">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="140"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="{x:Bind Key}"
                                           FontWeight="SemiBold"
                                           FontSize="12"
                                           TextWrapping="Wrap"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                <TextBlock Grid.Column="1"
                                           Text="{x:Bind Value}"
                                           FontSize="12"
                                           TextWrapping="Wrap"
                                           IsTextSelectionEnabled="True"/>
                            </Grid>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
